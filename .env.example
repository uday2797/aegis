# EPAM DIAL API (Azure OpenAI-compatible proxy)
DIAL_API_KEY=
DIAL_API_ENDPOINT=https://ai-proxy.lab.epam.com
DIAL_DEPLOYMENT=gpt-5.5-2026-04-24             # Job Fixer — reasoning model for deep notebook repair
DIAL_RCA_DEPLOYMENT=gpt-4o                     # RCA agent — fast standard model for root cause JSON output
DIAL_API_VERSION=2025-04-01-preview

# Databricks (optional - uses simulation mode if not set)
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-databricks-token
DATABRICKS_JOB_ID=123456

# Notifications — optional
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/your-webhook

# Slack Webhook (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# Gmail Notifications
# Requires Gmail 2-Step Verification + App Password
# Generate at: Google Account → Security → App Passwords
GMAIL_SENDER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
GMAIL_RECIPIENTS=recipient1@gmail.com,recipient2@gmail.com

# GitHub PR Creation (optional)
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=your-repo

# AEGIS Config
AEGIS_ENV=demo                    # demo | production
AEGIS_LOG_LEVEL=INFO
SIMULATION_MODE=true              # true = use simulated data, false = real Databricks

# Databricks user email — used to resolve notebook paths in config.yaml
# (replaces ${DATABRICKS_USER_EMAIL} placeholders)
DATABRICKS_USER_EMAIL=you@company.com
